// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. TABLA CURSO 
model Curso {
  id              String    @id
  nombre          String
  codigo          String    @unique
  descripcion     String
  color           String
  proposito       String?
  contenidos      String[]
  programaOficial String?

  recursos        Recurso[] // Relación: Un curso tiene muchos recursos
}

// 2. TABLA RECURSO 
model Recurso {
  id        Int     @id @default(autoincrement())
  tipo      String  
  titulo    String
  url       String
  duracion  String? 
  tamano    String? 

  cursoId   String
  curso     Curso   @relation(fields: [cursoId], references: [id])
}

// 3. TABLA ESTUDIANTE
model Estudiante {
  id        Int     @id @default(autoincrement())
  nombre    String
  matricula String  @unique
  programa  String
  foto      String?
}

// 4. TABLA INSIGNIA (Gamificación)
model Insignia {
  id          Int     @id @default(autoincrement())
  nombre      String
  nivel       String
  descripcion String
  icon        String
  color       String
  requisito   Int
}

model Alumno {
  id     Int    @id @default(autoincrement())
  nombre String
  email  String @unique
}

// 5. TABLA UNIDAD (Para la materia de Compiladores)
model Unidad {
  id          Int         @id @default(autoincrement())
  nombre      String
  contenidos  Contenido[] // Relación: Una unidad tiene muchos contenidos
}

// 6. TABLA CONTENIDO
model Contenido {
  id          Int           @id @default(autoincrement())
  titulo      String
  descripcion String
  tipo        TipoContenido @default(LECCION)
  orden       Int
  url_recurso String?       
  contenido   String[]      // Arreglo de textos para los párrafos

  // Llave foránea para conectarlo con su Unidad
  unidadId    Int
  unidad      Unidad        @relation(fields: [unidadId], references: [id])
}

// Opciones estáticas (Enum)
enum TipoContenido {
  LECCION
  RECURSO
  TAREA
}