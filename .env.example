# Copia este archivo como .env en local.
# En producción define estas variables en Railway/VPS, no las subas con valores reales.

NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://usuario:password@host:puerto/base

# Requeridas en producción. Deben coincidir con el frontend.
AUTH_SECRET=cambia-este-secreto-largo-para-firmar-tokens
AUTH_TRANSPORT_SECRET=cambia-este-secreto-largo-para-cifrado-frontend-backend

# Opcional: restringe CORS a dominios concretos separados por coma.
# Si no se define, el backend acepta cualquier origen.
CORS_ORIGIN=http://localhost:3000

# Cuentas iniciales. Se crean sólo si no existen.
DEFAULT_ADMIN_EMAIL=admin@ipn.mx
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_MODERATOR_1_EMAIL=moderador1@ipn.mx
DEFAULT_MODERATOR_1_PASSWORD=Moderador123!

# Correo para recuperación de contraseña.
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=contrasena_o_app_password
